# Microsoft Graph API 認証情報（必須）
GRAPH_CLIENT_ID=your-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-here
GRAPH_TENANT_ID=your-tenant-id-here

# OneDrive / SharePoint 対象リソース
GRAPH_ONEDRIVE_USER_ID=user@example.com
GRAPH_SHAREPOINT_SITE_ID=your-site-id-here
GRAPH_SHAREPOINT_DRIVE_ID=your-drive-id-here

# 設定ファイルパス（省略時は configs/config.json を自動検索）
# CONFIG_PATH=configs/config.json
